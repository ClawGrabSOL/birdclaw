{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "buildCommand": null,
  "outputDirectory": "public",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index" },
    { "source": "/((?!.*\\.[a-z0-9]+$).*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/index.js": {
      "maxDuration": 10,
      "memory": 256,
      "includeFiles": "node_modules/sql.js/dist/sql-wasm.wasm"
    }
  }
}
